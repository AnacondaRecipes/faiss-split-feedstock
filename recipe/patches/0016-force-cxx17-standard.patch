From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Xianglong Kong <xkong@anaconda.com>
Date: Fri, 4 Apr 2026 00:00:00 +0000
Subject: [PATCH] Force C++17 on non-MSVC, keep C++20 on MSVC

Upstream v1.14.1 defaults to C++20. On non-MSVC compilers (GCC, Clang),
force C++17 for broader compatibility. On MSVC, keep C++20 because
faiss v1.14.1 uses C++20 template lambdas in simd_dispatch.h that
MSVC requires C++20 mode for. This cannot be done via cmake -D flag
because the CMakeLists.txt set() call overrides cache variables.

---
 CMakeLists.txt              | 8 +++++---
 faiss/python/CMakeLists.txt | 8 +++++---
 2 files changed, 10 insertions(+), 6 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -53,11 +53,13 @@
   LANGUAGES ${FAISS_LANGUAGES})
 include(GNUInstallDirs)

-if(FAISS_ENABLE_CUVS)
-  set(CMAKE_CXX_STANDARD 17)
-else()
+if(MSVC)
+  # MSVC requires C++20 for template lambdas used in simd_dispatch.h
   set(CMAKE_CXX_STANDARD 20)
-endif()
+else()
+  # GCC/Clang: use C++17 for broader compatibility
+  set(CMAKE_CXX_STANDARD 17)
+endif()

 list(APPEND CMAKE_MODULE_PATH "${PROJECT_SOURCE_DIR}/cmake")

diff --git a/faiss/python/CMakeLists.txt b/faiss/python/CMakeLists.txt
--- a/faiss/python/CMakeLists.txt
+++ b/faiss/python/CMakeLists.txt
@@ -10,11 +10,13 @@
   HOMEPAGE_URL "https://github.com/facebookresearch/faiss"
   LANGUAGES CXX)

-if(FAISS_ENABLE_CUVS)
-  set(CMAKE_CXX_STANDARD 17)
-else()
+if(MSVC)
+  # MSVC requires C++20 for template lambdas used in simd_dispatch.h
   set(CMAKE_CXX_STANDARD 20)
-endif()
+else()
+  # GCC/Clang: use C++17 for broader compatibility
+  set(CMAKE_CXX_STANDARD 17)
+endif()

 find_package(SWIG REQUIRED COMPONENTS python)
 include(${SWIG_USE_FILE})
